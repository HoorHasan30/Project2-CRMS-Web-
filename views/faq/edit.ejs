<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit FAQ</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <%- include('../partials/navbar') %>
    <div class="content">
        <h1><a href="/faq">←</a>Edit FAQ</h1>

        <div class="faq-form">
            <form action="/faq/<%= faq._id %>?_method=PUT" method="POST">
            
                <div class="form-group">
                    <label for="question">Question:</label>
                    <input type="text" name="question" id="question" value="<%= faq.question %>">
                </div>

                <div class="form-group">
                    <label for="answer">Answer:</label>
                    <textarea name="answer" id="answer"><%= faq.answer %></textarea>
                </div>

                <button type="submit" class="faq-btn">Save</button>
            </form>
        </div>
    </div>
</body>
</html>