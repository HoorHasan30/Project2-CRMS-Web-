<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Categories</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <%- include('../partials/navbar') %>
    <div class="content">
        <h1>All Categories</h1>

        <div class="header">
            <div class="new-btn">
                <p>+ Add Category</p>
            </div>
        </div>
        <div class="categories-container">
            <% if (allCat && allCat.length) { %>
                <% allCat.forEach(cat => { %>
                    <div class="cat-card">
                        <div class="cat-title">
                            <div class="cat-title-form">
                                <form action="/categories/<%= cat._id %>/edit?_method=PUT" method="POST">
                                    <input type="checkbox" name="isActive" <%= cat.isActive ? "checked" : " " %> onchange="this.form.submit()">
                                </form>
                            </div>
                            <div class="cat-title-text">
                                <p><%= cat.name %></p>
                            </div>
                        </div>
                        <div class="cat-active">
                            <a href="categories/<%= cat._id %>">View Sub-Categories</a>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>


        <!-- Add: Modal Container -->
        <div class="modal">
            <div class="modal-content" id="cat-index">
                <div class="modal-title">
                    <h2><span class="back">←</span>Add Category</h2>
                </div>
                <div class="add-form">
                    <form action="/categories" method="POST">
                        <div class="form-group">
                            <label for="name">Category Name:</label>
                            <input type="text" id="name" name="name">
                        </div>
                        <div class="btns-group">
                            <button type="submit" class="add-btn">Add</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        const newBtn = document.querySelector('.new-btn')
        const addBtn = document.querySelector('.add-btn')
        const back = document.querySelector('.back')

        const modalE = document.querySelector('.modal')

        // Functions
        function showAddModal(){
            modalE.style.display = "flex"
        }
        function closeAddModal(){
            modalE.style.display = "none"
        }

        // Event Listeners
        newBtn.addEventListener('click', showAddModal)
        addBtn.addEventListener('click', closeAddModal)
        back.addEventListener('click', closeAddModal)
    </script>
</body>
</html>