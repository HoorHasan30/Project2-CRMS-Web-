<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ticket Details</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <%- include('../partials/navbar') %>
    <div class="content">
        <h1>
            <% if(user.isAdmin) { %> <a href="/tickets">←</a> <% } else { %> <a href="/tickets/myTickets">←</a> <% } %>
            Ticket Details
        </h1>

        
        <% if(ticket.status == "Pending" && ticket.owner._id == user._id) { %> 
            <div class="ticket-btns">
                <div class="edit-tic">
                    <form action="/tickets/<%= ticket._id %>/edit" method="GET">
                        <button type="submit" class="edit-tik">✎</button>
                    </form>      
                </div>
                <div class="delete-tic">
                    <form action="/tickets/<%= ticket._id %>/delete?_method=DELETE" method="POST">
                        <button type="submit" class="delete-tik">🗑</button>
                    </form>    
                </div>
        </div> 
        <% } %>
        
        <form id="new-ticket">
            <div class="form-group">
                <label for="owner">By: </label>
                <input disabled type="text" name="owner" id="owner" value="<%= ticket.owner.username %>">
            </div>

            <div class="form-group">
                <label for="status">Status: </label>
                <input disabled type="text" name="status" id="status" value="<%= ticket.status %>">
            </div>
            
            <% if(ticket.status == "Assigned"){ %> 
                <div class="form-group">
                    <label for="prioraty">Prioraty:</label>
                    
                    <select disabled name="prioraty" id="prioraty">
                        <option value=""><%= ticket.prioraty %></option>
                    </select>
                </div>

                <div class="form-group">
                    <label for="technician">Technician:</label>

                    <select disabled name="technician" id="technician">
                        <option value=""><%= ticket.technician.firstName %> <%= ticket.technician.lastName %></option>
                    </select>
                </div>
            <% } %>

            <div class="form-group">
                <label for="category">Category:</label>

                <select disabled name="category" id="category">
                    <option><%= ticket.category.name %></option>
                </select>
            </div>

            <div class="form-group">
                <label for="subCategory">Sub-Category:</label>

                <select disabled name="subCategory" id="subCategory">
                    <option><% if (ticket.subCategory) { %><%= ticket.subCategory.name %> <% } %></option>
                </select>
            </div>

            <div class="form-group">
                <label for="description">Description:</label>
                <textarea disabled name="description" id="description"><%= ticket.description %></textarea>
            </div>

            <div class="form-group">
                <label for="building">Building:</label>
                <input disabled type="text" name="building" id="building" value="<% if (ticket.building) { %><%= ticket.building %><% } %>">
            </div>

            <div class="form-group">
                <label for="room">Room:</label>
                <input disabled type="text" name="room" id="room" value="<% if (ticket.room) { %><%= ticket.room %><% } %>">
            </div>
        </form>

        <% if(user.isAdmin && !ticket.prioraty && !ticket.technician && ticket.status != "Rejected") { %>
            <div class="tik-btns">
                <form action="/tickets/<%= ticket._id %>/reject?_method=PUT" method="POST" class="tic-form">
                    <button type="submit" class="reject">Reject</button>
                </form>

                <form action="/tickets/<%= ticket._id %>/assign" method="GET" class="tic-form">
                    <button type="submit" id="assign">Assign</button>
                </form>    
            </div>
        <% } %>

        <% if(user.isAdmin && ticket.prioraty && ticket.technician && ticket.status == "Assigned") { %>
            <form action="/tickets/<%= ticket._id %>/completed?_method=PUT" method="POST" class="tic-form">
                <button type="submit" class="completed-tik">Completed</button>
            </form>    
        <% } %>

        <% if( ticket.status == "Completed" && ticket.owner._id == user._id && !ticket.feedback) { %>
            <button type="submit" class="feedback">Give Feedback</button>   
        <% } else if ( user.isAdmin && ticket.feedback ) {%>
            <button type="submit" class="feedback">View Feedback</button>
        <% } %>
    </div>

        <% if(ticket.owner._id == user._id && !ticket.feedback) { %>
            <!-- Add FeedBack: Modal Container -->
            <div class="modal">
                <div class="modal-content" id="cat-index">
                    <div class="modal-title">
                        <h2><span class="back">←</span>Ticket FeedBack</h2>
                    </div>
                    <div class="add-form">
                        <form action="/tickets/<%= ticket._id %>/feedback?_method=PUT" method="POST">
                            <div class="form-group">
                                <label for="feedbackInput">Write a FeedBack</label>
                                <textarea type="text" id="feedbackInput" name="feedback"></textarea>
                            </div>
                            <div class="btns-group">
                                <button type="submit" class="add-btn">Send</button>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        <% } else if (ticket.feedback && ticket.owner._id == user._id || user.isAdmin ) { %> 
            <!-- Add FeedBack: Modal Container -->
            <div class="modal">
                <div class="modal-content" id="cat-index">
                    <div class="modal-title">
                        <h2><span class="back">←</span>Ticket FeedBack</h2>
                    </div>
                    <div class="add-form">
                        <form>
                            <div class="form-group">
                                <label for="feedbackInput">Write a FeedBack</label>
                                <textarea disabled type="text" id="feedbackInput" name="feedback"><%= ticket.feedback %></textarea>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        <% } %>

        <script>
        const feedbackBtn = document.querySelector('.feedback')
        const addBtn = document.querySelector('.add-btn')
        const back = document.querySelectorAll('.back')

        const modalE = document.querySelector('.modal')

        // Functions
        function showAddModal(){
            if (modalE) modalE.style.display = 'flex'
        }
        function closeAddModal(){
            if (modalE) modalE.style.display = 'none'
        }

        // Event Listeners
        if (feedbackBtn) feedbackBtn.addEventListener('click', showAddModal)
        if (addBtn) addBtn.addEventListener('click', closeAddModal)
        back.forEach(b => b.addEventListener('click', closeAddModal))
    </script>
    
</body>
</html>